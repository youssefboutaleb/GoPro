      {
        "name": "sales_director",
        "description": "Sales Director role"
      },
      {
        "name": "supervisor",
        "description": "Supervisor role"
      },
      {
        "name": "delegate",
        "description": "Delegate role"
      },
      {
        "name": "uma_authorization",
        "description": "${role_uma_authorization}",
        "composite": false,
        "clientRole": false,
        "containerId": "medico"
      },
      {
        "name": "default-roles-medico",
        "description": "${role_default-roles}",
        "composite": true,
        "clientRole": false,
        "containerId": "medico"
      }
    ]
  },
  "groups": [
